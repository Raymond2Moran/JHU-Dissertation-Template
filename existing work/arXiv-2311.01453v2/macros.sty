\makeatletter  % Make example environment indented as a list, about 1em
\newenvironment{example}[1][]{
  \refstepcounter{example}
  \ifthenelse{\isempty{#1}}{%
    \list{}{%
      \itemindent\parindent
      \leftmargin1em  % Indentation amount on each side
      \rightmargin\leftmargin
      \parsep\z@\@plus\p@
    }%
  \item\relax % No number on the item
    \noindent \textbf{Example \theexample:}\hspace*{.05em}
    % There is no text to display in the example
  }{%
    \list{}{%
      \itemindent\parindent
      \leftmargin1em
      \rightmargin\leftmargin
      \parsep\z@\@plus\p@
    }%
  \item\relax % No number on the item
    \noindent \textbf{Example \theexample} ({#1})\textbf{:}\hspace*{.05em}
    % There is no text to display in the example
  }
}{%
  $\Diamond$ \endlist
}
\makeatother

